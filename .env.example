# Ollama 服务地址
OLLAMA_HOST=http://localhost:11434

# 嵌入模型（需先执行: ollama pull nomic-embed-text）
EMBED_MODEL=nomic-embed-text

# 对话模型（需先执行: ollama pull qwen2.5:7b）
CHAT_MODEL=qwen2.5:7b

# 数据与索引目录（相对于项目根目录）
DATA_DIR=./data
STORAGE_DIR=./storage

# 分块与检索参数
CHUNK_SIZE=500
CHUNK_OVERLAP=80
TOP_K=4
RETRIEVE_N=12
SIMILARITY_THRESHOLD=0.3
HYBRID_SEARCH=true

# 嵌入批大小与日志
EMBED_BATCH_SIZE=32
LOG_LEVEL=INFO

# 多轮对话：检索时参考最近 N 轮用户问题
CHAT_HISTORY_TURNS=3

# 嵌入并发线程数
EMBED_WORKERS=4

# HyDE / 查询改写 / Agentic 重检索 / Graph 章节加权
USE_HYDE=false
USE_QUERY_REWRITE=false
USE_AGENTIC_RAG=true
AGENTIC_MIN_SCORE=0.35
USE_GRAPH_RAG=true

# 扫描版 PDF OCR（需 pip install -r requirements-ocr.txt）
OCR_ENABLED=true
OCR_MIN_TEXT_LEN=50

# Streamlit 默认语言 zh | en
UI_LANG=zh

# 多模态：PDF 内嵌图 / 独立图片 → 视觉模型描述后入库（需 ollama pull llava）
USE_MULTIMODAL=false
VISION_MODEL=llava
MULTIMODAL_MAX_IMAGES=10

# Ollama 服务地址
OLLAMA_HOST=http://localhost:11434

# 嵌入模型（需先执行: ollama pull nomic-embed-text）
EMBED_MODEL=nomic-embed-text

# 对话模型（需先执行: ollama pull qwen2.5:7b）
CHAT_MODEL=qwen2.5:7b

# 数据与索引目录（相对于项目根目录）
DATA_DIR=./data
STORAGE_DIR=./storage

# 分块与检索参数
CHUNK_SIZE=500
CHUNK_OVERLAP=80
TOP_K=4
RETRIEVE_N=12
SIMILARITY_THRESHOLD=0.3
HYBRID_SEARCH=true

# 嵌入批大小与日志
EMBED_BATCH_SIZE=32
LOG_LEVEL=INFO

# 多轮对话：检索时参考最近 N 轮用户问题
CHAT_HISTORY_TURNS=3

# 嵌入并发线程数
EMBED_WORKERS=4

# HyDE / 查询改写 / Agentic 重检索 / Graph 章节加权
USE_HYDE=false
USE_QUERY_REWRITE=false
USE_AGENTIC_RAG=true
AGENTIC_MIN_SCORE=0.35
USE_GRAPH_RAG=true

# 扫描版 PDF OCR（需 pip install -r requirements/ocr.txt）
OCR_ENABLED=true
OCR_MIN_TEXT_LEN=50

# Streamlit 默认语言 zh | en
UI_LANG=zh

# 多模态：PDF 内嵌图 / 独立图片 → 视觉模型描述后入库（需 ollama pull llava）
USE_MULTIMODAL=false
VISION_MODEL=llava
MULTIMODAL_MAX_IMAGES=10

# 视觉描述缓存（增量索引时复用，避免重复 describe）
USE_VISION_CACHE=true

# 视频抽帧（需 requirements/video.txt）
VIDEO_FRAME_INTERVAL_SEC=5
VIDEO_MAX_FRAMES=20

# CLIP 图文双索引（需 requirements/clip.txt）
USE_CLIP=false
CLIP_MODEL=clip-ViT-B-32

# 生产化（API）
API_KEY=
TENANT_ID=
METRICS_ENABLED=true
AUTH_MODE=api_key
JWT_SECRET=
JWT_EXPIRE_MINUTES=1440
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
PROMETHEUS_ENABLED=true

# 向量库: local | qdrant | milvus
VECTOR_BACKEND=local
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_chunks
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=rag_chunks

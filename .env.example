# Ollama 服务地址
OLLAMA_HOST=http://localhost:11434

# 嵌入模型（需先执行: ollama pull nomic-embed-text）
EMBED_MODEL=nomic-embed-text

# 对话模型（需先执行: ollama pull qwen2.5:7b）
CHAT_MODEL=qwen2.5:7b

# 数据与索引目录（相对于项目根目录）
DATA_DIR=./data
STORAGE_DIR=./storage

# 分块与检索参数
CHUNK_SIZE=500
CHUNK_OVERLAP=80
TOP_K=4
